## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# ASP.NET generated files
Generated_Code/

# IIS Express
/.vs/
/iisexpress/

# SQL Server files
*.mdf
*.ldf

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# Restore packages except build/
*.nuget.props
*.nuget.targets

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# TFS
$tf/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# JetBrains Rider
.idea/

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# StyleCop
StyleCopReport.xml

# Publish Web Output
*.Publish.xml
*.pubxml
!*.pubxml.user

# Microsoft Azure Web App publish settings
*.azurePubxml

# Backup & report files
*.bak
*.backup
*.log
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Node modules (if frontend assets exist)
node_modules/

# appsettings/local configs
appsettings.Development.json

# Database backup files
*.dbmdl

# Entity Framework
*.edmx.diagram